# Public site url (used for canonical + OG tags + sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Medusa backend (fill in once backend is up)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Payments (server-only)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=

# Cloudinary (media)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Feature flags — leave unset (or any truthy value) for default ON.
# Set to `off` / `false` / `0` to kill a specific moment in production.
NEXT_PUBLIC_VISUAL_V2=
NEXT_PUBLIC_HERO_VARIANT=
NEXT_PUBLIC_HAMPER_BUILDER=
NEXT_PUBLIC_HOME_SECTION_ENTRY=
NEXT_PUBLIC_HOME_SEP_HERO=
NEXT_PUBLIC_HOME_EDITORIAL_BAND=
NEXT_PUBLIC_HOME_INGREDIENT_MARQUEE=

# Static export / GitHub Pages (set only for the deploy workflow)
# BUILD_TARGET=github-pages
# PAGES_BASE_PATH=/ravisweets
