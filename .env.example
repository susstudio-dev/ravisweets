# ─── Supabase ─────────────────────────────────────────────────────────────
# Provision a free Supabase project at https://supabase.com (free tier:
# 50K MAU, 500MB Postgres, 1GB Storage, 2GB egress/mo). Then copy the
# project URL and `anon` public key from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ─── Phone OTP via MSG91 ──────────────────────────────────────────────────
# Sign up at https://msg91.com (India-native, ~Rs 0.15/SMS, handles DLT
# registration as a service). Once your DLT sender ID + OTP template clears
# (2-7 days), set this flag to true to expose the Phone tab in the AuthModal.
NEXT_PUBLIC_PHONE_OTP_ENABLED=false

# ─── Feature flags ────────────────────────────────────────────────────────
# Toggle features off without removing the code paths.
NEXT_PUBLIC_AUTH_ENABLED=true
NEXT_PUBLIC_COUPONS_ENABLED=true
NEXT_PUBLIC_ADMIN_ENABLED=true
NEXT_PUBLIC_CMS_ENABLED=false

# ─── Build target ─────────────────────────────────────────────────────────
# Set to `github-pages` for the static export deploy. Leave unset for local dev.
# BUILD_TARGET=github-pages
